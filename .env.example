# CyberAI Configuration
# Copy to .env and fill in your values

# === LLM API Keys ===
GLM_API_KEY=your_bigmodel_api_key_here
# ANTHROPIC_API_KEY=your_claude_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# === Alibaba Cloud ===
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_REGION=us-west-1
ALIYUN_OSS_BUCKET=cyberai-results-uswest
ALIYUN_OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./cyberai.db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === Scanner ===
SCANNER_DEFAULT_MODEL=glm-5.1
SCANNER_MAX_PARALLEL=4
SCANNER_TOKEN_BUDGET=100000
SCANNER_TIME_BUDGET=600
